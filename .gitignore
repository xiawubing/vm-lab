# === Large binary artifacts (download/generate locally) ===

# QEMU disk images (base cloud images + per-CVE working overlays)
images/

# Kernel packages (.deb), FAT disk images, source trees, tarballs
kernel/

# Full kernel source trees and tarballs
linux-*/
linux-*.tar.xz

# === Generated artifacts (recreated automatically on first run) ===

# cloud-init seed ISOs (generated by start_vm scripts)
cloud-init/*/seed.iso

# === kernelctf large artifacts (download via setup.sh) ===

# VM filesystem images, ramdisks, qcow2 overlays
kernelctf/images/

# Kernel bzImage binaries
kernelctf/releases/

# Exploit build artifacts (rebuilt by run.sh each invocation)
kernelctf/exp/
kernelctf/exp-interactive/
kernelctf/exploit

# Static dropbear binaries (built by setup.sh)
kernelctf/init-interactive/dropbear
kernelctf/init-interactive/dropbearkey

# Smoke test results (large, machine-generated)
kernelctf/smoke-results/

# Runtime logs and diagnostics
kernelctf/logs/
kernelctf/setup-failed.log
agent-logs/

# Benchmark data (machine-generated)
kernelctf/benchmark_baseline.json
kernelctf/benchmark_record.jsonl
kernelctf/benchmark_results/

# Generated reports and plans
PROGRESS_REPORT.md
kernelctf/*_REPORT.md
kernelctf/*_PLAN.md
kernelctf/*_GUIDE.md
kernelctf/*_ANALYSIS.md

# === Local Claude Code settings ===
.claude/settings.local.json

# Agent container generated artifacts
agent-container/empty-src/
agent-container/docker-compose.override.yml

# === Runtime / editor artifacts ===
*.swp
*.swo
*~
.DS_Store
__pycache__/
*.pyc
