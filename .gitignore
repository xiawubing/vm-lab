# === Large binary artifacts (download/generate locally) ===

# QEMU disk images (base cloud images + per-CVE working overlays)
images/

# Kernel packages (.deb), FAT disk images, source trees, tarballs
kernel/

# Full kernel source trees and tarballs
linux-*/
linux-*.tar.xz

# === Generated artifacts (recreated automatically on first run) ===

# cloud-init seed ISOs (generated by start_vm scripts)
cloud-init/*/seed.iso

# === kernelctf large artifacts (download via setup.sh) ===

# VM filesystem images, ramdisks, qcow2 overlays
kernelctf/images/

# Kernel bzImage binaries
kernelctf/releases/

# Compiled exploit binaries (rebuild from source)
kernelctf/exp/exploit
kernelctf/exp-interactive/exploit

# Runtime logs
kernelctf/logs/

# === Local Claude Code settings ===
.claude/settings.local.json

# === Runtime / editor artifacts ===
*.swp
*.swo
*~
.DS_Store
__pycache__/
*.pyc
