{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /workspace/.claude/hooks/session_start.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /workspace/.claude/hooks/post_tool_use.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /workspace/.claude/hooks/post_tool_use.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /workspace/.claude/hooks/post_tool_use.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /workspace/.claude/hooks/post_tool_use.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /workspace/.claude/hooks/post_tool_use.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__vm-ssh__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /workspace/.claude/hooks/post_tool_use.py",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /workspace/.claude/hooks/stop_gate.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
